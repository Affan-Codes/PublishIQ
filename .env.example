# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=publishiq
DATABASE_URL=postgresql://postgres:postgrespassword@postgres:5432/publishiq?sslmode=disable

# Redis Configuration
REDIS_URL=redis://redis:6379

# Encryption Secrets
SESSION_SECRET=dev-session-secret-with-32-characters!!
ENCRYPTION_KEY=dev-encryption-key-with-32-characters!!

# Application Settings
PORT=4000
NODE_ENV=development
LOG_LEVEL=debug
MEDIA_ROOT=/usr/src/app/media
QUEUE_PREFIX=publishiq

# Operator / Admin Account Credentials
OPERATOR_EMAIL=admin@publishiq.com
OPERATOR_PASSWORD=admin1234_default_secret_passphrase

# Frontend / App URL
VITE_API_BASE_URL=http://localhost:4000/api/v1
APP_BASE_URL=http://localhost:4000
