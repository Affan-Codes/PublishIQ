# ==========================================
# Server & Environment Configuration
# ==========================================
NODE_ENV=development
PORT=4000
API_VERSION=v1
CORS_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:4000
LOG_LEVEL=debug

# ==========================================
# Database & Queue Storage Configuration
# ==========================================
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/publishiq?sslmode=disable
REDIS_URL=redis://localhost:6379
MEDIA_ROOT=./media
QUEUE_PREFIX=publishiq

# ==========================================
# Security & Encryption Secrets
# ==========================================
SESSION_SECRET=dev-session-secret-with-32-characters!!
ENCRYPTION_KEY=dev-encryption-key-with-32-characters!!
ENCRYPTION_SALT=publishiq_secure_static_salt_v1_change_in_production!

# ==========================================
# Default Operator Account Credentials
# ==========================================
OPERATOR_EMAIL=admin@publishiq.com
OPERATOR_PASSWORD=admin1234_default_secret_passphrase

# ==========================================
# AI Provider Configuration (Google Gemini)
# ==========================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ==========================================
# Meta Integration (Facebook & Instagram)
# ==========================================
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
META_GRAPH_API_VERSION=v20.0

# ==========================================
# Google Integration (YouTube)
# ==========================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

